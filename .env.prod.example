GITHUB_REPO=your-username/your-repo

POSTGRES_USER=duskforge
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=duskforge
DATABASE_URL=postgres://duskforge:your-secure-password@db:5432/duskforge?sslmode=disable

SERVER_PORT=8080
LOG_LEVEL=info

TMDB_API_KEY=your-tmdb-api-key

ACCESS_TOKEN_SECRET=your-access-token-secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRY=168h

# OAuth Configuration
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_REDIRECT_BASE=https://your-domain.com
OAUTH_STATE_SECRET=your-oauth-state-secret
